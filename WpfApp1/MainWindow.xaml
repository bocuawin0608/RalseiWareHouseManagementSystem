<Window x:Class="RalseiWarehouse.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:views="clr-namespace:RalseiWarehouse.Views"
        Title="Ralsei Warehouse Management" Height="760" Width="1200" MinHeight="600" MinWidth="900" WindowStartupLocation="CenterScreen" Background="{StaticResource Neutral100}">
    <DockPanel>
        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Padding="20,12" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center">Ralsei</TextBlock>
                    <TextBlock FontSize="12" Foreground="#A5B4FC" VerticalAlignment="Center" Margin="8,0,0,2">Warehouse Management</TextBlock>
                </StackPanel>
                <Border Grid.Column="2" Padding="14,8" CornerRadius="8" Background="#2D2B6B">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" Text="{Binding User.DisplayName}"/>
                        <TextBlock FontSize="11" Foreground="#A5B4FC" VerticalAlignment="Center" Margin="8,0,0,0" Text="{Binding User.Role.DisplayName}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Tab navigation + content -->
        <TabControl Margin="16" Background="Transparent">
            <TabItem Header="Master Data" Visibility="{Binding IsManager, Converter={StaticResource BoolToVisibility}}">
                <views:MasterDataView DataContext="{Binding MasterData}" Margin="0,8,0,0"/>
            </TabItem>
            <TabItem Header="Transactions">
                <views:TransactionView DataContext="{Binding Transactions}" Margin="0,8,0,0"/>
            </TabItem>
            <TabItem Header="Inventory" Visibility="{Binding IsManager, Converter={StaticResource BoolToVisibility}}">
                <views:InventoryView DataContext="{Binding Inventory}" Margin="0,8,0,0"/>
            </TabItem>
            <TabItem Header="Administration" Visibility="{Binding IsAdministrator, Converter={StaticResource BoolToVisibility}}">
                <views:AdministrationView DataContext="{Binding Administration}" Margin="0,8,0,0"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
