<UserControl x:Class="RalseiWarehouse.Views.AdministrationView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><DockPanel><TextBlock DockPanel.Dock="Bottom" Margin="8" Foreground="Firebrick" Text="{Binding Message}"/><TabControl><TabItem Header="Roles"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition/></Grid.ColumnDefinitions><DataGrid ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" AutoGenerateColumns="True" IsReadOnly="True"/><StackPanel Grid.Column="1" Margin="12"><TextBox Text="{Binding SelectedRole.DisplayName}"/><StackPanel Orientation="Horizontal"><Button Content="New" Command="{Binding NewRoleCommand}"/><Button Content="Save" Command="{Binding SaveRoleCommand}"/><Button Content="Delete" Command="{Binding DeleteRoleCommand}"/></StackPanel></StackPanel></Grid></TabItem><TabItem Header="Users"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition/></Grid.ColumnDefinitions><DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" AutoGenerateColumns="False" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/><DataGridTextColumn Header="Username" Binding="{Binding UserName}"/><DataGridTextColumn Header="Role" Binding="{Binding Role.DisplayName}"/></DataGrid.Columns></DataGrid><StackPanel Grid.Column="1" Margin="12"><TextBlock Text="Name"/><TextBox Text="{Binding SelectedUser.DisplayName}"/><TextBlock Text="Username"/><TextBox Text="{Binding SelectedUser.UserName}"/><TextBlock Text="Role"/><ComboBox ItemsSource="{Binding Roles}" DisplayMemberPath="DisplayName" SelectedValuePath="RoleId" SelectedValue="{Binding SelectedUser.RoleId}"/><TextBlock Text="New password (blank keeps current)"/><TextBox Text="{Binding NewPassword}"/><StackPanel Orientation="Horizontal"><Button Content="New" Command="{Binding NewUserCommand}"/><Button Content="Save" Command="{Binding SaveUserCommand}"/><Button Content="Delete" Command="{Binding DeleteUserCommand}"/></StackPanel></StackPanel></Grid></TabItem></TabControl></DockPanel></UserControl>
