<UserControl x:Class="RalseiWarehouse.Views.AdministrationView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource Neutral100}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Message}" Style="{StaticResource MessageText}" Foreground="{StaticResource Error}" Margin="0,0,0,12"/>

        <TabControl Grid.Row="1" Background="Transparent">
            <!-- Roles -->
            <TabItem Header="Roles">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                        <DataGrid ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Label}">Role Name</TextBlock>
                            <TextBox Text="{Binding SelectedRole.DisplayName}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button Content="New" Command="{Binding NewRoleCommand}" Style="{StaticResource BtnSecondary}" Padding="12,8"/>
                                <Button Content="Save" Command="{Binding SaveRoleCommand}" Margin="8,0,0,0" Padding="12,8"/>
                                <Button Content="Delete" Command="{Binding DeleteRoleCommand}" Style="{StaticResource BtnDanger}" Margin="8,0,0,0" Padding="12,8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Users -->
            <TabItem Header="Users">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                        <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                                <DataGridTextColumn Header="Username" Binding="{Binding UserName}" Width="*"/>
                                <DataGridTextColumn Header="Role" Binding="{Binding Role.DisplayName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Label}">Name</TextBlock>
                                <TextBox Text="{Binding SelectedUser.DisplayName}"/>
                                <TextBlock Style="{StaticResource Label}">Username</TextBlock>
                                <TextBox Text="{Binding SelectedUser.UserName}"/>
                                <TextBlock Style="{StaticResource Label}">Role</TextBlock>
                                <ComboBox ItemsSource="{Binding Roles}" DisplayMemberPath="DisplayName" SelectedValuePath="RoleId" SelectedValue="{Binding SelectedUser.RoleId}"/>
                                <TextBlock Style="{StaticResource Label}">New Password</TextBlock>
                                <TextBox Text="{Binding NewPassword}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="New" Command="{Binding NewUserCommand}" Style="{StaticResource BtnSecondary}" Padding="12,8"/>
                                    <Button Content="Save" Command="{Binding SaveUserCommand}" Margin="8,0,0,0" Padding="12,8"/>
                                    <Button Content="Delete" Command="{Binding DeleteUserCommand}" Style="{StaticResource BtnDanger}" Margin="8,0,0,0" Padding="12,8"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
