<UserControl x:Class="RalseiWarehouse.Views.TransactionView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource Neutral100}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Message}" Foreground="{StaticResource Neutral700}" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent">
            <!-- Import Tab -->
            <TabItem Header="New Import">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="12" Foreground="{StaticResource Neutral500}">Purchase Price = what you paid the supplier · Sell Price = what you will charge customers</TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="40,0,0,0">
                            <Button Content="+ Add Line" Command="{Binding AddInputCommand}" Style="{StaticResource BtnSecondary}" Padding="14,9" FontSize="13"/>
                            <Button Content="Complete Import" Command="{Binding SaveInputCommand}" Margin="10,0,0,0" Padding="16,9" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <DataGrid ItemsSource="{Binding InputLines}" CanUserAddRows="False" AutoGenerateColumns="False" RowHeight="44">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Product" Width="2*" MinWidth="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=DataGrid}}" DisplayMemberPath="DisplayName" SelectedItem="{Binding Product}" Margin="6,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Qty" Binding="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                <DataGridTextColumn Header="Purchase Price (per unit)" Binding="{Binding InputPrice, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                                <DataGridTextColumn Header="Sell Price (per unit)" Binding="{Binding OutputPrice, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                                <DataGridTemplateColumn Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Remove" Command="{Binding DataContext.RemoveInputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource BtnDanger}" Padding="8,4" FontSize="12" Margin="4,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Export Tab -->
            <TabItem Header="New Export">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource Label}" VerticalAlignment="Center" Margin="0,0,8,0">Customer</TextBlock>
                        <ComboBox Grid.Column="1" Width="280" ItemsSource="{Binding Customers}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedCustomer}" Margin="0"/>
                        <Button Grid.Column="2" Content="+ Add Line" Command="{Binding AddOutputCommand}" Style="{StaticResource BtnSecondary}" Padding="14,9" FontSize="13" Margin="20,0,0,0"/>
                        <Button Grid.Column="3" Content="Complete Export" Command="{Binding SaveOutputCommand}" Margin="10,0,0,0" Padding="16,9" FontSize="13"/>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <DataGrid ItemsSource="{Binding OutputLines}" CanUserAddRows="False" AutoGenerateColumns="False" RowHeight="44">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Product" Width="2*" MinWidth="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=DataGrid}}" DisplayMemberPath="DisplayName" SelectedItem="{Binding Product}" Margin="6,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Quantity" Binding="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                <DataGridTemplateColumn Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Remove" Command="{Binding DataContext.RemoveOutputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource BtnDanger}" Padding="8,4" FontSize="12" Margin="4,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- History Tab -->
            <TabItem Header="History">
                <TabControl Margin="0,12,0,0" Background="Transparent">
                    <TabItem Header="Recent Imports">
                        <Border Style="{StaticResource Card}" Padding="0" Margin="0,12,0,0">
                            <DataGrid ItemsSource="{Binding RecentImports}" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="36">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Receipt ID" Binding="{Binding InputId}" Width="2*"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding DateInput, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="*"/>
                                    <DataGridTextColumn Header="Items" Binding="{Binding InputInfos.Count}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </TabItem>
                    <TabItem Header="Recent Exports">
                        <Border Style="{StaticResource Card}" Padding="0" Margin="0,12,0,0">
                            <DataGrid ItemsSource="{Binding RecentExports}" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="36">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Receipt ID" Binding="{Binding OutputId}" Width="2*"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding DateOutput, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="*"/>
                                    <DataGridTextColumn Header="Items" Binding="{Binding OutputInfos.Count}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
