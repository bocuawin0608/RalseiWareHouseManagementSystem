<Window x:Class="RalseiWarehouse.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Warehouse - Login" Height="340" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Warehouse Management" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="Sign in to continue" FontSize="13" Foreground="Gray"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <TextBox x:Name="txtUsername" Height="30" Margin="0,0,0,10"/>

            <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <PasswordBox x:Name="txtPassword" Height="30" Margin="0,0,0,14"/>

            <TextBlock x:Name="txtMessage" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,10"
                       HorizontalAlignment="Center"/>

            <Button Content="Sign In" Height="36" Click="BtnLogin_Click" IsDefault="True"
                    FontSize="14" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
