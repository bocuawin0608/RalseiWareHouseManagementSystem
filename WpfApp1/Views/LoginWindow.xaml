<Window x:Class="RalseiWarehouse.Views.LoginWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ralsei Warehouse — Login" Height="480" Width="420" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="{StaticResource Neutral100}">
    <Grid>
        <Border Width="360" Height="400" CornerRadius="16" Background="{StaticResource Surface}" BorderBrush="{StaticResource Neutral200}" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="12" Color="#CBD5E1" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel Margin="32,36">
                <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource Primary700}" HorizontalAlignment="Center">Ralsei</TextBlock>
                <TextBlock FontSize="14" Foreground="{StaticResource Neutral500}" HorizontalAlignment="Center" Margin="0,0,0,28">Warehouse Management</TextBlock>
                <Rectangle Height="1" Fill="{StaticResource Neutral200}" Margin="0,0,0,20"/>
                <TextBlock Style="{StaticResource Label}">Username</TextBlock>
                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Padding="12,10"/>
                <TextBlock Style="{StaticResource Label}" Margin="0,4,0,4">Password</TextBlock>
                <PasswordBox PasswordChanged="PasswordChanged" Padding="12,10"/>
                <TextBlock Style="{StaticResource MessageText}" Foreground="{StaticResource Error}" TextWrapping="Wrap" Text="{Binding Message}" MaxHeight="40"/>
                <Button Content="Sign In" Command="{Binding LoginCommand}" Height="42" FontSize="15" Margin="0,16,0,0" IsDefault="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
