<Window x:Class="RalseiWarehouse.Views.LoginWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Ralsei Warehouse — Login" Height="320" Width="430" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="45"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock FontSize="26" FontWeight="SemiBold" Text="Ralsei Warehouse"/><TextBox Grid.Row="1" Margin="0,25,0,5" Padding="7" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" ToolTip="Username"/>
        <PasswordBox Grid.Row="2" Margin="0,5" Padding="7" PasswordChanged="PasswordChanged"/><TextBlock Grid.Row="3" Margin="0,8" Foreground="Firebrick" TextWrapping="Wrap" Text="{Binding Message}"/>
        <Button Grid.Row="4" HorizontalAlignment="Right" MinWidth="110" Padding="10,6" IsDefault="True" Content="Sign in" Command="{Binding LoginCommand}"/>
    </Grid>
</Window>
