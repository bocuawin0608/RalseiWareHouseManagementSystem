<UserControl x:Class="RalseiWarehouse.Views.MasterDataView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource Neutral100}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="⟳ Refresh" Command="{Binding LoadCommand}" Style="{StaticResource BtnSecondary}" Padding="12,8" FontSize="13"/>
            <TextBlock Text="{Binding Message}" Style="{StaticResource MessageText}" Foreground="{StaticResource Neutral700}" VerticalAlignment="Center" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Tabbed content -->
        <TabControl Grid.Row="1" Background="Transparent">
            <TabItem Header="Units of Measure">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                        <DataGrid ItemsSource="{Binding Units}" SelectedItem="{Binding SelectedUnit}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding UnitId}" Width="60"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Label}">Unit Name</TextBlock>
                            <TextBox Text="{Binding SelectedUnit.DisplayName}"/>
                            <TextBlock FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,8" TextWrapping="Wrap">e.g. Kg, Box, Piece, Liter — this is how products are measured.</TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button Content="New" Command="{Binding NewUnitCommand}" Style="{StaticResource BtnSecondary}" Padding="12,8"/>
                                <Button Content="Save" Command="{Binding SaveUnitCommand}" Margin="8,0,0,0" Padding="12,8"/>
                                <Button Content="Delete" Command="{Binding DeleteUnitCommand}" Style="{StaticResource BtnDanger}" Margin="8,0,0,0" Padding="12,8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Suppliers">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                        <DataGrid ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Label}">Name</TextBlock>
                                <TextBox Text="{Binding SelectedSupplier.DisplayName}"/>
                                <TextBlock Style="{StaticResource Label}">Address</TextBlock>
                                <TextBox Text="{Binding SelectedSupplier.Address}"/>
                                <TextBlock Style="{StaticResource Label}">Phone</TextBlock>
                                <TextBox Text="{Binding SelectedSupplier.Phone}"/>
                                <TextBlock Style="{StaticResource Label}">Email</TextBlock>
                                <TextBox Text="{Binding SelectedSupplier.Email}"/>
                                <TextBlock Style="{StaticResource Label}">Notes</TextBlock>
                                <TextBox Text="{Binding SelectedSupplier.MoreInfo}"/>
                                <TextBlock Style="{StaticResource Label}">Contract Date</TextBlock>
                                <DatePicker SelectedDate="{Binding SelectedSupplier.ContractDate}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="New" Command="{Binding NewSupplierCommand}" Style="{StaticResource BtnSecondary}" Padding="12,8"/>
                                    <Button Content="Save" Command="{Binding SaveSupplierCommand}" Margin="8,0,0,0" Padding="12,8"/>
                                    <Button Content="Delete" Command="{Binding DeleteSupplierCommand}" Style="{StaticResource BtnDanger}" Margin="8,0,0,0" Padding="12,8"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Customers">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                        <DataGrid ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Label}">Name</TextBlock>
                                <TextBox Text="{Binding SelectedCustomer.DisplayName}"/>
                                <TextBlock Style="{StaticResource Label}">Address</TextBlock>
                                <TextBox Text="{Binding SelectedCustomer.Address}"/>
                                <TextBlock Style="{StaticResource Label}">Phone</TextBlock>
                                <TextBox Text="{Binding SelectedCustomer.Phone}"/>
                                <TextBlock Style="{StaticResource Label}">Email</TextBlock>
                                <TextBox Text="{Binding SelectedCustomer.Email}"/>
                                <TextBlock Style="{StaticResource Label}">Notes</TextBlock>
                                <TextBox Text="{Binding SelectedCustomer.MoreInfo}"/>
                                <TextBlock Style="{StaticResource Label}">Contract Date</TextBlock>
                                <DatePicker SelectedDate="{Binding SelectedCustomer.ContractDate}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="New" Command="{Binding NewCustomerCommand}" Style="{StaticResource BtnSecondary}" Padding="12,8"/>
                                    <Button Content="Save" Command="{Binding SaveCustomerCommand}" Margin="8,0,0,0" Padding="12,8"/>
                                    <Button Content="Delete" Command="{Binding DeleteCustomerCommand}" Style="{StaticResource BtnDanger}" Margin="8,0,0,0" Padding="12,8"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Products">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                        <DataGrid ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                                <DataGridTextColumn Header="Unit" Binding="{Binding Unit.DisplayName}" Width="80"/>
                                <DataGridTextColumn Header="Supplier" Binding="{Binding Supplier.DisplayName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Label}">Product ID</TextBlock>
                                <TextBox Text="{Binding SelectedProduct.Id}"/>
                                <TextBlock Style="{StaticResource Label}">Name</TextBlock>
                                <TextBox Text="{Binding SelectedProduct.DisplayName}"/>
                                <TextBlock Style="{StaticResource Label}">Unit of Measure</TextBlock>
                                <ComboBox ItemsSource="{Binding Units}" DisplayMemberPath="DisplayName" SelectedValuePath="UnitId" SelectedValue="{Binding SelectedProduct.UnitId}"/>
                                <TextBlock FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,-4,0,8">How this product is counted (Kg, Box, Piece…)</TextBlock>
                                <TextBlock Style="{StaticResource Label}">Supplier</TextBlock>
                                <ComboBox ItemsSource="{Binding Suppliers}" DisplayMemberPath="DisplayName" SelectedValuePath="SupplierId" SelectedValue="{Binding SelectedProduct.SupplierId}"/>
                                <TextBlock Style="{StaticResource Label}">QR Code</TextBlock>
                                <TextBox Text="{Binding SelectedProduct.QRCode}"/>
                                <TextBlock Style="{StaticResource Label}">Barcode</TextBlock>
                                <TextBox Text="{Binding SelectedProduct.BarCode}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="New" Command="{Binding NewProductCommand}" Style="{StaticResource BtnSecondary}" Padding="12,8"/>
                                    <Button Content="Save" Command="{Binding SaveProductCommand}" Margin="8,0,0,0" Padding="12,8"/>
                                    <Button Content="Delete" Command="{Binding DeleteProductCommand}" Style="{StaticResource BtnDanger}" Margin="8,0,0,0" Padding="12,8"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
