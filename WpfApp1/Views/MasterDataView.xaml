<UserControl x:Class="RalseiWarehouse.Views.MasterDataView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <DockPanel><StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"><TextBlock Margin="8" Foreground="Firebrick" Text="{Binding Message}"/><Button Content="Refresh" Command="{Binding LoadCommand}"/></StackPanel><TabControl>
  <TabItem Header="Units"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition/></Grid.ColumnDefinitions><DataGrid ItemsSource="{Binding Units}" SelectedItem="{Binding SelectedUnit}" AutoGenerateColumns="False" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="ID" Binding="{Binding UnitId}"/><DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/></DataGrid.Columns></DataGrid><StackPanel Grid.Column="1" Margin="12"><TextBlock Text="Name"/><TextBox Text="{Binding SelectedUnit.DisplayName}"/><StackPanel Orientation="Horizontal"><Button Content="New" Command="{Binding NewUnitCommand}"/><Button Content="Save" Command="{Binding SaveUnitCommand}"/><Button Content="Delete" Command="{Binding DeleteUnitCommand}"/></StackPanel></StackPanel></Grid></TabItem>
  <TabItem Header="Suppliers"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition/></Grid.ColumnDefinitions><DataGrid ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" AutoGenerateColumns="False" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/><DataGridTextColumn Header="Phone" Binding="{Binding Phone}"/><DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/></DataGrid.Columns></DataGrid><StackPanel Grid.Column="1" Margin="12"><TextBlock Text="Name"/><TextBox Text="{Binding SelectedSupplier.DisplayName}"/><TextBlock Text="Address"/><TextBox Text="{Binding SelectedSupplier.Address}"/><TextBlock Text="Phone"/><TextBox Text="{Binding SelectedSupplier.Phone}"/><TextBlock Text="Email"/><TextBox Text="{Binding SelectedSupplier.Email}"/><TextBlock Text="Notes"/><TextBox Text="{Binding SelectedSupplier.MoreInfo}"/><DatePicker SelectedDate="{Binding SelectedSupplier.ContractDate}"/><StackPanel Orientation="Horizontal"><Button Content="New" Command="{Binding NewSupplierCommand}"/><Button Content="Save" Command="{Binding SaveSupplierCommand}"/><Button Content="Delete" Command="{Binding DeleteSupplierCommand}"/></StackPanel></StackPanel></Grid></TabItem>
  <TabItem Header="Customers"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition/></Grid.ColumnDefinitions><DataGrid ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" AutoGenerateColumns="False" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/><DataGridTextColumn Header="Phone" Binding="{Binding Phone}"/><DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/></DataGrid.Columns></DataGrid><StackPanel Grid.Column="1" Margin="12"><TextBlock Text="Name"/><TextBox Text="{Binding SelectedCustomer.DisplayName}"/><TextBlock Text="Address"/><TextBox Text="{Binding SelectedCustomer.Address}"/><TextBlock Text="Phone"/><TextBox Text="{Binding SelectedCustomer.Phone}"/><TextBlock Text="Email"/><TextBox Text="{Binding SelectedCustomer.Email}"/><TextBlock Text="Notes"/><TextBox Text="{Binding SelectedCustomer.MoreInfo}"/><DatePicker SelectedDate="{Binding SelectedCustomer.ContractDate}"/><StackPanel Orientation="Horizontal"><Button Content="New" Command="{Binding NewCustomerCommand}"/><Button Content="Save" Command="{Binding SaveCustomerCommand}"/><Button Content="Delete" Command="{Binding DeleteCustomerCommand}"/></StackPanel></StackPanel></Grid></TabItem>
  <TabItem Header="Products"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition/></Grid.ColumnDefinitions><DataGrid ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" AutoGenerateColumns="False" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="ID" Binding="{Binding Id}"/><DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/><DataGridTextColumn Header="Unit" Binding="{Binding Unit.DisplayName}"/><DataGridTextColumn Header="Supplier" Binding="{Binding Supplier.DisplayName}" Width="*"/></DataGrid.Columns></DataGrid><StackPanel Grid.Column="1" Margin="12"><TextBlock Text="Product ID"/><TextBox Text="{Binding SelectedProduct.Id}"/><TextBlock Text="Name"/><TextBox Text="{Binding SelectedProduct.DisplayName}"/><TextBlock Text="Unit"/><ComboBox ItemsSource="{Binding Units}" DisplayMemberPath="DisplayName" SelectedValuePath="UnitId" SelectedValue="{Binding SelectedProduct.UnitId}"/><TextBlock Text="Supplier"/><ComboBox ItemsSource="{Binding Suppliers}" DisplayMemberPath="DisplayName" SelectedValuePath="SupplierId" SelectedValue="{Binding SelectedProduct.SupplierId}"/><TextBlock Text="QR code"/><TextBox Text="{Binding SelectedProduct.QRCode}"/><TextBlock Text="Barcode"/><TextBox Text="{Binding SelectedProduct.BarCode}"/><StackPanel Orientation="Horizontal"><Button Content="New" Command="{Binding NewProductCommand}"/><Button Content="Save" Command="{Binding SaveProductCommand}"/><Button Content="Delete" Command="{Binding DeleteProductCommand}"/></StackPanel></StackPanel></Grid></TabItem>
 </TabControl></DockPanel>
</UserControl>
