<Window x:Class="RalseiWarehouse.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Warehouse Management System" Height="720" Width="1200"
        MinHeight="550" MinWidth="900" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- TOP BAR -->
        <Border DockPanel.Dock="Top" Padding="16,10" Background="#1e3a5f">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="WAREHOUSE" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Management System" FontSize="12" Foreground="#8ab4f8"
                               VerticalAlignment="Center" Margin="8,0,0,2"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="txtUserName" Foreground="White" VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                    <Button Content="Logout" Width="65" Height="26" Margin="14,0,0,0"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN TABS -->
        <TabControl x:Name="tabMain" Margin="8" SelectionChanged="TabMain_SelectionChanged">

            <!-- ═══ TAB 1: MASTER DATA ═══ -->
            <TabItem x:Name="tabMasterData" Header="Master Data">
                <TabControl Margin="0,8,0,0">

                    <!-- UNITS -->
                    <TabItem Header="Units">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid x:Name="dgUnits" AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" SelectionChanged="DgUnits_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding UnitId}" Width="60"/>
                                    <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="Unit Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtUnitName" Height="28" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="New" Width="60" Click="BtnNewUnit_Click"/>
                                    <Button Content="Save" Width="60" Margin="6,0,0,0" Click="BtnSaveUnit_Click"/>
                                    <Button Content="Delete" Width="60" Margin="6,0,0,0" Click="BtnDeleteUnit_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- SUPPLIERS -->
                    <TabItem Header="Suppliers">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid x:Name="dgSuppliers" AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" SelectionChanged="DgSuppliers_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="100"/>
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <ScrollViewer Grid.Column="2" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Name" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtSupplierName" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Address" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtSupplierAddr" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Phone" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtSupplierPhone" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtSupplierEmail" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtSupplierNotes" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Contract Date" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <DatePicker x:Name="dpSupplierDate" Height="26" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="New" Width="60" Click="BtnNewSupplier_Click"/>
                                        <Button Content="Save" Width="60" Margin="6,0,0,0" Click="BtnSaveSupplier_Click"/>
                                        <Button Content="Delete" Width="60" Margin="6,0,0,0" Click="BtnDeleteSupplier_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- CUSTOMERS -->
                    <TabItem Header="Customers">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid x:Name="dgCustomers" AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" SelectionChanged="DgCustomers_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="100"/>
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <ScrollViewer Grid.Column="2" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Name" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtCustomerName" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Address" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtCustomerAddr" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Phone" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtCustomerPhone" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtCustomerEmail" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtCustomerNotes" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Contract Date" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <DatePicker x:Name="dpCustomerDate" Height="26" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="New" Width="60" Click="BtnNewCustomer_Click"/>
                                        <Button Content="Save" Width="60" Margin="6,0,0,0" Click="BtnSaveCustomer_Click"/>
                                        <Button Content="Delete" Width="60" Margin="6,0,0,0" Click="BtnDeleteCustomer_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- PRODUCTS -->
                    <TabItem Header="Products">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid x:Name="dgProducts" AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" SelectionChanged="DgProducts_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                                    <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit.DisplayName}" Width="80"/>
                                    <DataGridTextColumn Header="Supplier" Binding="{Binding Supplier.DisplayName}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <ScrollViewer Grid.Column="2" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Product ID" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtProductId" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Name" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtProductName" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Unit" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <ComboBox x:Name="cboProductUnit" Height="28" Margin="0,0,0,6"
                                              DisplayMemberPath="DisplayName" SelectedValuePath="UnitId"/>
                                    <TextBlock Text="Supplier" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <ComboBox x:Name="cboProductSupplier" Height="28" Margin="0,0,0,6"
                                              DisplayMemberPath="DisplayName" SelectedValuePath="SupplierId"/>
                                    <TextBlock Text="QR Code" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtProductQR" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Barcode" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtProductBarcode" Height="26" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="New" Width="60" Click="BtnNewProduct_Click"/>
                                        <Button Content="Save" Width="60" Margin="6,0,0,0" Click="BtnSaveProduct_Click"/>
                                        <Button Content="Delete" Width="60" Margin="6,0,0,0" Click="BtnDeleteProduct_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- ═══ TAB 2: TRANSACTIONS ═══ -->
            <TabItem x:Name="tabTransactions" Header="Transactions">
                <TabControl Margin="0,8,0,0">

                    <!-- IMPORT -->
                    <TabItem Header="New Import">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="+ Add Line" Width="90" Click="BtnAddImportLine_Click"/>
                                <Button Content="Complete Import" Width="120" Margin="10,0,0,0"
                                        Click="BtnCompleteImport_Click"/>
                                <TextBlock x:Name="txtImportMessage" Foreground="Green"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <DataGrid x:Name="dgImportLines" Grid.Row="1" AutoGenerateColumns="False"
                                      CanUserAddRows="False" RowHeight="35">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Product" Width="2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding Products, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="DisplayName" SelectedItem="{Binding Product}" Margin="4,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Qty" Binding="{Binding Count}" Width="70"/>
                                    <DataGridTextColumn Header="Purchase Price" Binding="{Binding InputPrice}" Width="110"/>
                                    <DataGridTextColumn Header="Sell Price" Binding="{Binding OutputPrice}" Width="100"/>
                                    <DataGridTemplateColumn Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Remove" Click="BtnRemoveImportLine_Click" Tag="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- EXPORT -->
                    <TabItem Header="New Export">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Customer:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <ComboBox x:Name="cboExportCustomer" Width="220" Height="28"
                                          DisplayMemberPath="DisplayName" SelectedValuePath="CustomerId"/>
                                <Button Content="+ Add Line" Width="90" Margin="16,0,0,0" Click="BtnAddExportLine_Click"/>
                                <Button Content="Complete Export" Width="120" Margin="10,0,0,0"
                                        Click="BtnCompleteExport_Click"/>
                                <TextBlock x:Name="txtExportMessage" Foreground="Green"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <DataGrid x:Name="dgExportLines" Grid.Row="1" AutoGenerateColumns="False"
                                      CanUserAddRows="False" RowHeight="35">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Product" Width="2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding Products, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="DisplayName" SelectedItem="{Binding Product}" Margin="4,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Qty" Binding="{Binding Count}" Width="80"/>
                                    <DataGridTemplateColumn Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Remove" Click="BtnRemoveExportLine_Click" Tag="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- HISTORY -->
                    <TabItem Header="History">
                        <TabControl Margin="10">
                            <TabItem Header="Recent Imports">
                                <DataGrid x:Name="dgRecentImports" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Receipt ID" Binding="{Binding InputId}" Width="*"/>
                                        <DataGridTextColumn Header="Date" Binding="{Binding DateInput, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="150"/>
                                        <DataGridTextColumn Header="Items" Binding="{Binding InputInfos.Count}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Recent Exports">
                                <DataGrid x:Name="dgRecentExports" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Receipt ID" Binding="{Binding OutputId}" Width="*"/>
                                        <DataGridTextColumn Header="Date" Binding="{Binding DateOutput, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="150"/>
                                        <DataGridTextColumn Header="Items" Binding="{Binding OutputInfos.Count}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- ═══ TAB 3: INVENTORY ═══ -->
            <TabItem x:Name="tabInventory" Header="Inventory">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="txtInventorySearch" Width="280" Height="28"
                                 TextChanged="TxtInventorySearch_TextChanged"/>
                        <Button Content="Refresh" Width="80" Height="28" Margin="10,0,0,0"
                                Click="BtnInventoryRefresh_Click"/>
                        <TextBlock x:Name="txtInventoryMessage" Foreground="Green"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <DataGrid x:Name="dgInventory" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 4: DASHBOARD ═══ -->
            <TabItem x:Name="tabDashboard" Header="Dashboard">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Button Content="Refresh Stats" Width="110" Height="28"
                                Click="BtnDashboardRefresh_Click"/>
                        <Button Content="Export CSV" Width="100" Height="28" Margin="10,0,0,0"
                                Click="BtnExportCsv_Click"/>
                        <Button Content="Export Report" Width="100" Height="28" Margin="10,0,0,0"
                                Click="BtnExportReport_Click"/>
                        <Button Content="Export JSON" Width="100" Height="28" Margin="10,0,0,0"
                                Click="BtnExportJson_Click"/>
                        <Button Content="Import JSON" Width="100" Height="28" Margin="10,0,0,0"
                                Click="BtnImportJson_Click"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1">
                        <StackPanel>
                            <TextBlock x:Name="txtDashboard" FontFamily="Consolas" FontSize="13"
                                       Margin="0,0,0,14"/>
                            <TextBlock x:Name="txtDashboardMessage" Foreground="Green"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 5: ADMINISTRATION ═══ -->
            <TabItem x:Name="tabAdmin" Header="Administration">
                <TabControl Margin="0,8,0,0">
                    <!-- ROLES -->
                    <TabItem Header="Roles">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid x:Name="dgRoles" AutoGenerateColumns="True" IsReadOnly="True"
                                      SelectionMode="Single" SelectionChanged="DgRoles_SelectionChanged"/>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="Role Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtRoleName" Height="28" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="New" Width="60" Click="BtnNewRole_Click"/>
                                    <Button Content="Save" Width="60" Margin="6,0,0,0" Click="BtnSaveRole_Click"/>
                                    <Button Content="Delete" Width="60" Margin="6,0,0,0" Click="BtnDeleteRole_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- USERS -->
                    <TabItem Header="Users">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid x:Name="dgUsers" AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" SelectionChanged="DgUsers_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                                    <DataGridTextColumn Header="Username" Binding="{Binding UserName}" Width="*"/>
                                    <DataGridTextColumn Header="Role" Binding="{Binding Role.DisplayName}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <ScrollViewer Grid.Column="2" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Display Name" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtUserDisplayName" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtUserUsername" Height="26" Margin="0,0,0,6"/>
                                    <TextBlock Text="Role" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <ComboBox x:Name="cboUserRole" Height="28" Margin="0,0,0,6"
                                              DisplayMemberPath="DisplayName" SelectedValuePath="RoleId"/>
                                    <TextBlock Text="New Password" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox x:Name="txtUserPassword" Height="26" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="New" Width="60" Click="BtnNewUser_Click"/>
                                        <Button Content="Save" Width="60" Margin="6,0,0,0" Click="BtnSaveUser_Click"/>
                                        <Button Content="Delete" Width="60" Margin="6,0,0,0" Click="BtnDeleteUser_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
