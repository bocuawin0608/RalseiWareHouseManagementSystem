<UserControl x:Class="RalseiWarehouse.Views.InventoryView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource Neutral100}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border CornerRadius="8" BorderBrush="{StaticResource Neutral300}" BorderThickness="1" Background="{StaticResource Surface}" Margin="0,0,10,0">
                <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Width="280" BorderThickness="0" Padding="10,8" Margin="0"/>
            </Border>
            <Button Content="Search / Refresh" Command="{Binding LoadCommand}" Style="{StaticResource BtnSecondary}" Padding="14,8"/>
            <TextBlock Text="{Binding Message}" Style="{StaticResource MessageText}" Foreground="{StaticResource Error}" VerticalAlignment="Center" Margin="12,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
