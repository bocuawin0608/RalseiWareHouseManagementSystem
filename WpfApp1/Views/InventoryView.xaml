<UserControl x:Class="RalseiWarehouse.Views.InventoryView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><DockPanel Margin="8"><StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><TextBox Width="280" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Search / Refresh" Command="{Binding LoadCommand}"/><TextBlock Margin="8" Foreground="Firebrick" Text="{Binding Message}"/></StackPanel><DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="True" IsReadOnly="True"/></DockPanel></UserControl>
