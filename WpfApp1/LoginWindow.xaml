<Window x:Class="RalseiWarehouse.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ralsei Warehouse - Login" Height="350" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Ralsei Warehouse" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Management System" FontSize="14" Foreground="Gray"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="txtUsername" Height="30" Margin="0,0,0,12"/>

            <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="txtPassword" Height="30" Margin="0,0,0,16"/>

            <TextBlock x:Name="txtMessage" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <Button x:Name="btnLogin" Content="Sign In" Height="35" Click="BtnLogin_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
