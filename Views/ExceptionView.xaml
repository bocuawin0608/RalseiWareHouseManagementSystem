<UserControl x:Class="RalseiWarehouse_v2.Views.ExceptionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Stock &amp; Exceptions" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Label Content="Quality" VerticalAlignment="Center"/>
                <ComboBox x:Name="cboQuality" Width="120" Height="24" Margin="4,0,8,0"
                          SelectionChanged="cboQuality_SelectionChanged">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="Available"/>
                    <ComboBoxItem Content="Quarantine"/>
                    <ComboBoxItem Content="Damaged"/>
                    <ComboBoxItem Content="Hold"/>
                </ComboBox>
                <Button x:Name="btnRefresh" Content="Refresh" Width="90" Height="26"
                        Click="btnRefresh_Click"/>
            </StackPanel>
        </DockPanel>

        <DataGrid Grid.Row="1" x:Name="dgStock" AutoGenerateColumns="True" IsReadOnly="True"
                  SelectionMode="Single"/>

        <GroupBox Grid.Row="2" Header="Exception action on selected row" Padding="10" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Label Content="Qty"/>
                <TextBox x:Name="txtQty" Width="70" Height="24" Margin="4"/>

                <Label Content="Reason" Margin="16,0,0,0"/>
                <TextBox x:Name="txtNote" Width="220" Height="24" Margin="4"/>

                <Label Content="Release to" Margin="16,0,0,0"/>
                <ComboBox x:Name="cboDestination" Width="110" Height="24" Margin="4"
                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"/>

                <Button x:Name="btnDamage" Content="Damage" Width="90" Height="28" Margin="16,0,0,0"
                        Click="btnDamage_Click"/>
                <Button x:Name="btnQuarantine" Content="Quarantine" Width="100" Height="28" Margin="8,0,0,0"
                        Click="btnQuarantine_Click"/>
                <Button x:Name="btnRelease" Content="Release" Width="90" Height="28" Margin="8,0,0,0"
                        Click="btnRelease_Click"/>
                <Button x:Name="btnCountAdjust" Content="Count adjust" Width="110" Height="28" Margin="8,0,0,0"
                        Click="btnCountAdjust_Click"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</UserControl>
